{
  "name": "pl_geo_risk_etl",
  "description": "Geo Risk batch ETL — metadata-driven parameters",
  "parameters": {
    "ENV": { "type": "string", "defaultValue": "dev" },
    "LAKEHOUSE": { "type": "string", "defaultValue": "lh_geo_risk_dev" },
    "MOCK_IPSTACK": { "type": "string", "defaultValue": "true" },
    "LOOKBACK_DAYS": { "type": "string", "defaultValue": "30" },
    "SOURCE_FILE": { "type": "string", "defaultValue": "events_100.csv" },
    "RUN_SETUP": { "type": "bool", "defaultValue": false }
  },
  "activities": [
    { "name": "Setup", "type": "TridentNotebook", "notebook": "2_setup", "condition": "@pipeline().parameters.RUN_SETUP" },
    { "name": "Cleanup", "type": "TridentNotebook", "notebook": "3_cleanup_old_tables" },
    { "name": "Bronze", "type": "TridentNotebook", "notebook": "4_bronze_loader", "dependsOn": ["Cleanup"] },
    { "name": "Silver", "type": "TridentNotebook", "notebook": "5_silver_loader", "dependsOn": ["Bronze"] },
    { "name": "Gold", "type": "TridentNotebook", "notebook": "6_gold_loader", "dependsOn": ["Silver"] }
  ],
  "notes": "Import this template in Fabric Data Pipeline UI. Map parameters to notebook base definitions."
}
